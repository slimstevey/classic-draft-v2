# =========================================
# SERVER (apps/server)
# =========================================

# Colyseus server port
PORT=2567
NODE_ENV=development

# JWT signing secret for player session tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars

# Admin & operator wallet addresses (lowercase, comma-separated for operators).
# Admin = full control. Operators = can create/manage rooms.
ADMIN_WALLET_ADDRESS=0x7e9fb80cb24de523c8165cd5119b77cde1f4a8e2
OPERATOR_WALLET_ADDRESSES=

# Sky Mavis Axie GraphQL API key (server-side only, never exposed to client).
SKY_MAVIS_API_KEY=

# CORS — the public URL where the web app is served.
CORS_ORIGIN=http://localhost:3000

# =========================================
# WEB (apps/web)
# =========================================

# Public Colyseus URLs (the client needs both WS and HTTP)
NEXT_PUBLIC_COLYSEUS_WS_URL=ws://localhost:2567
NEXT_PUBLIC_COLYSEUS_HTTP_URL=http://localhost:2567

# Discord OAuth (https://discord.com/developers/applications)
# Redirect URI in Discord dev portal must match exactly:
#   {PUBLIC_WEB_URL}/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
PUBLIC_WEB_URL=http://localhost:3000

# Session cookie signing secret (must match JWT_SECRET for the server,
# OR be a separate cookie-only secret if you want session-cookie isolation).
# Simplest: reuse JWT_SECRET so the server can verify player tokens directly.
JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars
